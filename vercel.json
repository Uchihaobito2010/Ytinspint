{
  "version": 2,
  "functions": {
    "api/yt.js": {
      "maxDuration": 30,
      "memory": 1024
    },
    "api/insta.js": {
      "maxDuration": 30,
      "memory": 1024
    },
    "api/pin.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/insta/video",
      "destination": "/api/insta.js"
    },
    {
      "source": "/api/pin/video",
      "destination": "/api/pin.js"
    }
  ]
}
