{
  "version": 2,
  "functions": {
    "api/*.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/api/yt",
      "methods": ["GET", "POST"],
      "dest": "/api/yt.js"
    },
    {
      "src": "/api/insta",
      "methods": ["GET", "POST"],
      "dest": "/api/insta.js"
    },
    {
      "src": "/api/pin",
      "methods": ["GET", "POST"],
      "dest": "/api/pin.js"
    }
  ]
}
